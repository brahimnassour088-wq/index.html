<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HorSolar — Énergie Solaire au Tchad</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,700;0,900;1,700&display=swap" rel="stylesheet">
    <style>
        :root {
            --blue: #0077cc;
            --blue2: #005fa3;
            --orange: #f5a623;
            --orange2: #e8941a;
            --dark: #0a0f1a;
            --dark2: #0f1824;
            --green: #25D366;
            --white: #f8fbff;
            --gray: #6b7a8d;
            --border: rgba(0,119,204,0.15);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Outfit', sans-serif; background: var(--dark); color: var(--white); overflow-x: hidden; }

        /* NAV */
        nav {
            padding: 14px 5vw;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0;
            background: rgba(10,15,26,0.97);
            backdrop-filter: blur(20px);
            z-index: 200;
            border-bottom: 1px solid var(--border);
        }
        .nav-logo { display: flex; align-items: center; gap: 10px; }
        .logo-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--orange), var(--blue));
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
        }
        .logo-text { display: flex; flex-direction: column; }
        .logo-name { font-size: 1.1rem; font-weight: 800; color: var(--white); letter-spacing: -0.02em; }
        .logo-sub { font-size: 0.6rem; color: var(--orange); letter-spacing: 0.15em; text-transform: uppercase; }
        .nav-wa {
            display: flex; align-items: center; gap: 6px;
            background: var(--green); color: white;
            padding: 9px 16px; border-radius: 100px;
            text-decoration: none; font-size: 0.82rem; font-weight: 700;
            box-shadow: 0 4px 16px rgba(37,211,102,0.3);
        }

        /* HERO */
        .hero {
            min-height: 100svh;
            position: relative; overflow: hidden;
            display: flex; flex-direction: column; justify-content: flex-end;
            padding: 0 5vw 60px;
        }

        /* Animated solar background */
        .hero-bg {
            position: absolute; inset: 0;
            background: linear-gradient(150deg, #0a1628 0%, #051020 50%, #0a1a0a 100%);
        }

        /* Grid of product photos */
        .hero-grid {
            position: absolute; inset: 0;
            display: grid; grid-template-columns: 1fr 1fr 1fr;
            grid-template-rows: 1fr 1fr;
            opacity: 0.2;
        }
        .hg { overflow: hidden; }
        .hg img { width: 100%; height: 100%; object-fit: cover; display: block; filter: saturate(60%); }

        .hero-ov {
            position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(10,15,26,1) 0%, rgba(10,15,26,0.85) 50%, rgba(10,15,26,0.5) 100%);
        }

        /* Sun animation */
        .hero-sun {
            position: absolute; top: 8%; right: 8%;
            width: 120px; height: 120px;
            background: radial-gradient(circle, rgba(245,166,35,0.4) 0%, rgba(245,166,35,0.1) 50%, transparent 70%);
            border-radius: 50%;
            animation: sunPulse 4s ease-in-out infinite;
        }
        .hero-sun::before {
            content: '☀️';
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-size: 3rem;
            filter: drop-shadow(0 0 20px rgba(245,166,35,0.8));
        }
        @keyframes sunPulse { 0%,100%{transform:scale(1);opacity:0.8;} 50%{transform:scale(1.1);opacity:1;} }

        /* Solar rays */
        .hero-rays {
            position: absolute; top: 0; right: 0; left: 0;
            height: 60%;
            background: repeating-conic-gradient(
                from 0deg at 85% 10%,
                rgba(245,166,35,0.03) 0deg 10deg,
                transparent 10deg 20deg
            );
            pointer-events: none;
        }

        .hero-content { position: relative; z-index: 2; }

        .hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(245,166,35,0.12);
            border: 1px solid rgba(245,166,35,0.3);
            color: var(--orange); padding: 6px 14px; border-radius: 100px;
            font-size: 0.72rem; font-weight: 700; letter-spacing: 0.05em;
            text-transform: uppercase; margin-bottom: 22px; width: fit-content;
        }
        .pulse { width: 7px; height: 7px; background: var(--orange); border-radius: 50%; animation: blink 2s infinite; }
        @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.8rem, 10vw, 5rem);
            font-weight: 900; line-height: 1.0;
            letter-spacing: -0.02em; margin-bottom: 8px;
        }
        .hero-title .blue { color: var(--blue); }
        .hero-title .orange { color: var(--orange); font-style: italic; }

        .hero-sub {
            font-size: 0.95rem; color: rgba(248,251,255,0.55);
            line-height: 1.75; margin-bottom: 30px; max-width: 360px;
        }
        .hero-sub strong { color: var(--white); font-weight: 600; }

        .hero-btns { display: flex; flex-direction: column; gap: 10px; }
        .btn-wa {
            display: flex; align-items: center; justify-content: center; gap: 10px;
            background: var(--green); color: white; padding: 17px; border-radius: 14px;
            text-decoration: none; font-weight: 700; font-size: 1rem;
            box-shadow: 0 8px 28px rgba(37,211,102,0.3);
        }
        .btn-outline {
            display: flex; align-items: center; justify-content: center; gap: 8px;
            background: rgba(0,119,204,0.1); border: 1px solid rgba(0,119,204,0.3);
            color: var(--blue); padding: 15px; border-radius: 14px;
            text-decoration: none; font-weight: 600; font-size: 0.9rem;
        }

        /* STATS */
        .stats {
            padding: 32px 5vw;
            background: var(--dark2);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
        }
        .stat {
            padding: 20px 16px; text-align: center;
            background: rgba(0,119,204,0.04);
        }
        .stat strong {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem; font-weight: 900;
            background: linear-gradient(135deg, var(--orange), var(--blue));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            display: block; line-height: 1;
        }
        .stat span { font-size: 0.72rem; color: rgba(248,251,255,0.45); margin-top: 4px; display: block; }

        /* ABOUT */
        .about { padding: 52px 5vw; background: var(--dark); position: relative; overflow: hidden; }
        .about::after {
            content: '☀️';
            position: absolute; right: 5vw; top: 50%; transform: translateY(-50%);
            font-size: 8rem; opacity: 0.04; pointer-events: none;
        }

        .sec-tag {
            display: inline-flex; align-items: center; gap: 8px;
            font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em;
            color: var(--orange); text-transform: uppercase; margin-bottom: 14px;
        }
        .sec-tag::before { content: '◆'; font-size: 0.5rem; }

        .sec-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.8rem, 6vw, 2.8rem); font-weight: 900;
            line-height: 1.08; margin-bottom: 18px;
        }
        .sec-title em { font-style: italic; color: var(--orange); }

        .about-text { font-size: 0.9rem; color: rgba(248,251,255,0.45); line-height: 1.8; margin-bottom: 28px; }

        .features { display: flex; flex-direction: column; gap: 10px; }
        .feat {
            display: flex; align-items: center; gap: 12px;
            padding: 14px 16px;
            background: rgba(0,119,204,0.05); border: 1px solid rgba(0,119,204,0.12);
            border-radius: 14px; font-size: 0.86rem; font-weight: 500;
            transition: all 0.2s;
        }
        .feat:hover { border-color: rgba(245,166,35,0.3); background: rgba(245,166,35,0.05); }
        .feat-dot {
            width: 28px; height: 28px;
            background: linear-gradient(135deg, var(--orange), var(--blue));
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            font-size: 0.75rem; flex-shrink: 0; font-weight: 800; color: white;
        }

        /* PRODUCTS */
        .products { padding: 52px 5vw; background: var(--dark2); }

        .prod-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 24px; }
        .prod-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(0,119,204,0.12);
            border-radius: 18px; overflow: hidden;
            transition: all 0.3s;
        }
        .prod-card:hover { border-color: rgba(245,166,35,0.35); transform: translateY(-3px); }
        .prod-img { width: 100%; aspect-ratio: 1; overflow: hidden; background: #fff; }
        .prod-img img { width: 100%; height: 100%; object-fit: contain; display: block; padding: 12px; }
        .prod-info { padding: 14px 14px 16px; }
        .prod-tag { font-size: 0.6rem; font-weight: 700; color: var(--orange); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 4px; display: block; }
        .prod-name { font-size: 0.88rem; font-weight: 700; margin-bottom: 6px; line-height: 1.3; }
        .prod-desc { font-size: 0.75rem; color: rgba(248,251,255,0.4); line-height: 1.5; }

        /* REALISATIONS */
        .realisations { padding: 52px 5vw; background: var(--dark); }

        .real-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 24px; }
        .real-item {
            border-radius: 14px; overflow: hidden;
            position: relative;
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        }
        .real-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
        .real-item:hover img { transform: scale(1.05); }
        .real-item.tall { grid-row: span 2; }
        .real-item:not(.tall) { aspect-ratio: 4/3; }
        .real-item.tall { aspect-ratio: 3/5; }

        .real-label {
            position: absolute; bottom: 0; left: 0; right: 0;
            padding: 20px 12px 10px;
            background: linear-gradient(to top, rgba(10,15,26,0.95), transparent);
            color: white;
        }
        .real-tag { display: block; font-size: 0.6rem; color: var(--orange); font-weight: 700; letter-spacing: 0.1em; margin-bottom: 2px; }
        .real-name { font-size: 0.78rem; font-weight: 600; }

        /* SERVICES */
        .services {
            padding: 52px 5vw;
            background: linear-gradient(150deg, var(--blue2) 0%, #021a35 100%);
            position: relative; overflow: hidden;
        }
        .services::before {
            content: '';
            position: absolute; top: -100px; right: -100px;
            width: 300px; height: 300px;
            background: radial-gradient(circle, rgba(245,166,35,0.15), transparent 70%);
            pointer-events: none;
        }

        .srv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 24px; }
        .srv-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px; padding: 22px 16px; transition: all 0.3s;
        }
        .srv-card:hover { background: rgba(245,166,35,0.08); border-color: rgba(245,166,35,0.3); }
        .srv-icon { font-size: 1.8rem; margin-bottom: 12px; display: block; }
        .srv-card h3 { font-size: 0.88rem; font-weight: 700; margin-bottom: 6px; }
        .srv-card p { font-size: 0.75rem; color: rgba(255,255,255,0.45); line-height: 1.6; }

        /* CTA */
        .cta {
            padding: 64px 5vw; text-align: center;
            background: var(--dark2); position: relative; overflow: hidden;
        }
        .cta::before {
            content: ''; position: absolute; top: 0; left: 5vw; right: 5vw; height: 1px;
            background: linear-gradient(90deg, transparent, var(--orange), transparent);
        }
        .cta::after {
            content: ''; position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(0,119,204,0.1), transparent 70%);
            pointer-events: none;
        }

        .cta-tag { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2em; color: var(--orange); text-transform: uppercase; margin-bottom: 16px; display: block; }
        .cta-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 8vw, 3.5rem); font-weight: 900; line-height: 1.05; margin-bottom: 12px;
        }
        .cta-title em { font-style: italic; color: var(--orange); }
        .cta-sub { font-size: 0.88rem; color: rgba(248,251,255,0.4); margin-bottom: 32px; line-height: 1.7; }

        .cta-btns { display: flex; flex-direction: column; gap: 10px; position: relative; z-index: 1; }
        .btn-wa-big {
            display: flex; align-items: center; justify-content: center; gap: 12px;
            background: var(--green); color: white; padding: 18px; border-radius: 14px;
            text-decoration: none; font-weight: 700; font-size: 1rem;
            box-shadow: 0 12px 36px rgba(37,211,102,0.3);
        }
        .btn-tel {
            display: flex; align-items: center; justify-content: center; gap: 10px;
            background: rgba(245,166,35,0.1); border: 1px solid rgba(245,166,35,0.3);
            color: var(--orange); padding: 17px; border-radius: 14px;
            text-decoration: none; font-weight: 600; font-size: 0.95rem;
        }

        /* INFO */
        .info { padding: 40px 5vw; background: var(--dark); }
        .info-cards { display: flex; flex-direction: column; gap: 8px; margin-top: 22px; }
        .info-card {
            display: flex; align-items: center; gap: 14px;
            background: rgba(0,119,204,0.05); border: 1px solid rgba(0,119,204,0.12);
            padding: 16px; border-radius: 14px;
        }
        .info-icon {
            width: 40px; height: 40px;
            background: linear-gradient(135deg, rgba(245,166,35,0.2), rgba(0,119,204,0.2));
            border: 1px solid rgba(245,166,35,0.2);
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
            font-size: 1rem; flex-shrink: 0;
        }
        .info-text strong { display: block; font-size: 0.85rem; font-weight: 700; color: var(--orange); margin-bottom: 2px; }
        .info-text span { font-size: 0.75rem; color: rgba(248,251,255,0.4); }

        /* FLOATING BUTTON */
        .float-btn {
            position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
            z-index: 300; width: calc(100% - 40px); max-width: 400px;
        }
        .float-btn a {
            display: flex; align-items: center; justify-content: center; gap: 10px;
            background: linear-gradient(135deg, var(--orange), var(--orange2));
            color: white; padding: 16px; border-radius: 100px;
            text-decoration: none; font-weight: 800; font-size: 0.95rem;
            box-shadow: 0 8px 30px rgba(245,166,35,0.4);
            animation: float 3s ease-in-out infinite;
        }
        @keyframes float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-4px);} }

        /* FOOTER */
        footer {
            padding: 28px 5vw; background: #050810;
            border-top: 1px solid rgba(0,119,204,0.12);
            text-align: center; padding-bottom: 90px;
        }
        .footer-logo { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 900; margin-bottom: 4px; }
        .footer-logo .blue { color: var(--blue); }
        .footer-logo .orange { color: var(--orange); }
        .footer-sub { font-size: 0.7rem; color: rgba(255,255,255,0.2); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 14px; }
        .footer-div { width: 50px; height: 1px; background: linear-gradient(90deg, transparent, var(--orange), transparent); margin: 0 auto 14px; }
        footer p { font-size: 0.72rem; color: rgba(255,255,255,0.2); margin-bottom: 4px; }
        footer a { color: var(--orange); text-decoration: none; }

        /* REVEAL */
        .reveal { opacity: 0; transform: translateY(28px); transition: all 0.7s ease; }
        .reveal.visible { opacity: 1; transform: translateY(0); }

        @media (min-width: 768px) {
            .hero { padding: 0 8vw 80px; }
            .hero-btns { flex-direction: row; max-width: 420px; }
            .prod-grid { grid-template-columns: repeat(3, 1fr); }
            .srv-grid { grid-template-columns: repeat(4, 1fr); }
            .cta-btns { flex-direction: row; justify-content: center; }
            .about, .products, .realisations, .services, .cta, .info { padding-left: 8vw; padding-right: 8vw; }
        }
    </style>
</head>
